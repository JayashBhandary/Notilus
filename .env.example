# Template for the P2P transfer backend config.
#
# SETUP: copy this file to `.env` (same folder, repo root) and fill in the two
# values from your Firebase project. `.env` is git-ignored; in CI these come
# from GitHub secrets (see .github/workflows/release.yml).
#
#   cp .env.example .env
#
# Where to find the values in the Firebase console:
#   rtdbUrl → Realtime Database → the URL at the top of the Data tab.
#   apiKey  → Project settings → General → "Web API Key".
#
# Loaded at runtime by flutter_dotenv (bundled as an asset, see pubspec.yaml).
# Just create `.env` and run/build normally — no extra flags needed.
TRANSFER_RTDB_URL=https://YOUR_PROJECT-default-rtdb.firebaseio.com
TRANSFER_API_KEY=YOUR_WEB_API_KEY
