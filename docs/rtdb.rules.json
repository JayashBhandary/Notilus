{
  "rules": {
    "users": {
      "$uid": {
        "profile": {
          ".read": true,
          ".write": "auth != null && auth.uid === $uid"
        },
        "inbox": {
          ".read": "auth != null && auth.uid === $uid",
          "$msg": {
            ".write": "auth != null"
          }
        }
      }
    },
    "codes": {
      "$code": {
        ".read": true,
        ".write": "auth != null && newData.child('uid').val() === auth.uid && (!data.exists() || data.child('uid').val() === auth.uid)"
      }
    }
  }
}
